# ── Firebase Configuration ───────────────────────────────────────────────────
# Dapatkan dari: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Encryption Key ───────────────────────────────────────────────────────────
# Kunci enkripsi untuk URL dan data - ganti dengan string acak yang aman!
# Contoh: gunakan https://generate-secret.vercel.app/32 untuk generate
NEXT_PUBLIC_ENCRYPT_KEY=your-super-secret-encryption-key-minimum-32-chars

# ── Admin UID ────────────────────────────────────────────────────────────────
# UID Firebase dari akun admin (dapatkan setelah register pertama kali)
# Setelah register, buka Firestore > users > [uid] dan ubah role menjadi "admin"
NEXT_PUBLIC_ADMIN_UID=your_admin_uid_here
